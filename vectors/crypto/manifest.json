      "tier": "L3",
      "kind": "run",
      "expect": "accept",
      "description": "A sealed three-event run: signed checkpoint plus every event's canonical bytes.",
      "artifact": "valid/crypto_run_valid_01.cbor"
    },
    {
      "id": "crypto.run.root_mismatch.01",
      "tier": "L3",
      "kind": "run",
      "expect": "reject",
      "failure_code": "record.root_mismatch",
