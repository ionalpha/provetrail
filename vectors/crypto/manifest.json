      "artifact": "valid/crypto_checkpoint_valid_01.cbor"
    },
    {
      "id": "crypto.checkpoint.unknown_key.01",
      "tier": "L2",
      "kind": "checkpoint",
      "expect": "reject",
      "failure_code": "sign.unknown_key",
      "description": "A checkpoint signed by a key whose public half is not in the keyring.",
      "artifact": "invalid/crypto_checkpoint_unknown_key_01.cbor"
    },
    {
      "id": "crypto.checkpoint.bad_signature.01",
      "tier": "L2",
      "kind": "checkpoint",
      "expect": "reject",
      "failure_code": "sign.signature_invalid",
      "description": "A valid checkpoint with its final signature byte flipped.",
      "artifact": "invalid/crypto_checkpoint_bad_signature_01.cbor"
    },
    {
      "id": "crypto.checkpoint.bad_content_type.01",
      "tier": "L2",
      "kind": "checkpoint",
      "expect": "reject",
      "failure_code": "sign.bad_content_type",
      "description": "A correctly signed COSE_Sign1 whose protected content type is not the checkpoint type.",
      "artifact": "invalid/crypto_checkpoint_bad_content_type_01.cbor"
    },
    {
      "id": "crypto.checkpoint.undecodable_payload.01",
      "tier": "L2",
      "kind": "checkpoint",
      "expect": "reject",
