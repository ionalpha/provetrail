      "artifact": "invalid/crypto_event_proof_bad_inclusion_01.cbor"
    },
    {
      "id": "crypto.event_proof.size_mismatch.01",
      "tier": "L3",
      "kind": "event_proof",
      "expect": "reject",
      "failure_code": "record.size_mismatch",
      "description": "A proof whose claimed tree size does not match the signed size.",
      "artifact": "invalid/crypto_event_proof_size_mismatch_01.cbor"
    },
    {
      "id": "crypto.event_proof.bad_signature.01",
      "tier": "L3",
      "kind": "event_proof",
      "expect": "reject",
      "failure_code": "sign.signature_invalid",
      "description": "A proof whose embedded checkpoint signature has been altered.",
      "artifact": "invalid/crypto_event_proof_bad_signature_01.cbor"
