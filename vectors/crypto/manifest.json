    {
      "id": "crypto.ground_truth.failed_check.01",
      "tier": "L4",
      "kind": "ground_truth",
      "expect": "reject",
      "failure_code": "shallow.no_ground_truth",
      "description": "A run claiming success bound to a check that did not pass.",
      "artifact": "invalid/crypto_ground_truth_failed_check_01.cbor"
