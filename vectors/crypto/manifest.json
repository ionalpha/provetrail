      "artifact": "invalid/crypto_run_root_mismatch_01.cbor"
    },
    {
      "id": "crypto.run.size_mismatch.01",
      "tier": "L3",
      "kind": "run",
      "expect": "reject",
      "failure_code": "record.size_mismatch",
      "description": "A run with one event removed so the count no longer matches the signed size.",
      "artifact": "invalid/crypto_run_size_mismatch_01.cbor"
    },
    {
      "id": "crypto.run.bad_signature.01",
      "tier": "L3",
      "kind": "run",
      "expect": "reject",
      "failure_code": "sign.signature_invalid",
      "description": "A run whose embedded checkpoint signature has been altered.",
      "artifact": "invalid/crypto_run_bad_signature_01.cbor"
    },
    {
      "id": "crypto.run.non_canonical.01",
      "tier": "L3",
      "kind": "run",
      "expect": "reject",
      "failure_code": "record.non_canonical",
      "description": "A run record carrying an extra map field, so it is not in canonical form.",
      "artifact": "invalid/crypto_run_non_canonical_01.cbor"
    },
    {
      "id": "crypto.event_proof.valid.01",
      "tier": "L3",
      "kind": "event_proof",
      "expect": "accept",
      "description": "A standalone proof that the second event is included under the signed root.",
