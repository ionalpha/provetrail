      "flags": [
        "Encoding"
      ],
      "description": "A canonical event followed by one extra trailing byte.",
      "events": [
        "invalid/invalid_enc_trailing_bytes_01.cbor"
      ]
    },
    {
      "id": "invalid.enc.duplicate_map_key.01",
      "expect": "reject",
