{
  "suite_version": "0.1.0-draft",
  "tier": "L1",
  "vectors": [
    {
      "id": "valid.minimal.01",
      "expect": "accept",
      "flags": [
        "Structural"
      ],
      "description": "A single minimal event with the required fields and an empty payload.",
      "events": [
        "valid/valid_minimal_01.cbor"
      ]
    },
    {
      "id": "valid.optional_fields.01",
      "expect": "accept",
      "flags": [
        "Structural"
      ],
      "description": "A single event carrying every optional field and a payload of mixed value types.",
      "events": [
        "valid/valid_optional_fields_01.cbor"
      ]
    },
    {
      "id": "valid.chain.01",
      "expect": "accept",
      "flags": [
        "Structural",
        "Ordering"
      ],
      "description": "Three events on one stream with strictly increasing Seq.",
      "events": [
        "valid/valid_chain_01_0.cbor",
        "valid/valid_chain_01_1.cbor",
        "valid/valid_chain_01_2.cbor"
      ]
    },
    {
